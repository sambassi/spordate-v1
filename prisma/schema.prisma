// Prisma Schema for Spordateur
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  referralCode  String?   @unique
  referredBy    String?
  role          String    @default("user") // user, admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  bookings      Booking[]
}

model Booking {
  id             String   @id @default(cuid())
  
  // Stripe info
  sessionId      String   @unique
  paymentStatus  String   @default("pending") // pending, paid, failed, expired
  
  // User relation
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  userEmail      String?
  
  // Partner/Profile info
  profileId      String
  profileName    String
  sport          String   @default("Afroboost")
  
  // Venue info
  partnerId      String?
  partnerName    String?
  partnerAddress String?
  
  // Ticket info
  ticketType     String   @default("solo") // solo, duo
  amount         Float    @default(25)
  currency       String   @default("EUR")
  
  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Session date (when the sport session will happen)
  sessionDate    DateTime?

  @@index([userId])
  @@index([sessionId])
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  type        String   @default("gym")
  referralId  String   @unique
  active      Boolean  @default(true) // Changed from isActive to active
  
  // New fields for admin management
  photoUrl    String?
  mapsUrl     String?
  priceSolo   Float    @default(25)
  priceDuo    Float    @default(50)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id                String   @id @default(cuid())
  key               String   @unique
  value             String
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
